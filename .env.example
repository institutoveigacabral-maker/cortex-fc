# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_REPLICA_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SHARE_SECRET=your_share_secret

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key
RAPIDAPI_KEY=your_rapidapi_key

# Email
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_SCOUT_MONTHLY=price_xxx
STRIPE_PRICE_SCOUT_YEARLY=price_xxx
STRIPE_PRICE_CLUB_MONTHLY=price_xxx
STRIPE_PRICE_CLUB_YEARLY=price_xxx
STRIPE_PRICE_HOLDING_MONTHLY=price_xxx
STRIPE_PRICE_HOLDING_YEARLY=price_xxx

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Sentry
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ORG=your_org
SENTRY_PROJECT=your_project

# Cron
CRON_SECRET=your_cron_secret
